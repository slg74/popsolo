<%
  # Circle of fifths: 12 keys at 30° increments, C at the top (−90° offset)
  fifths = %w[C G D A E B F# C# G# D# A# F]
  cx = 220; cy = 220
  r_outer = 190; r_inner = 95; r_label = 150
  deg_per_key = 30

  def arc_path(cx, cy, r_inner, r_outer, start_deg, end_deg)
    to_rad = ->(d) { (d - 90) * Math::PI / 180 }
    s = to_rad.call(start_deg); e = to_rad.call(end_deg)
    x1 = cx + r_outer * Math.cos(s); y1 = cy + r_outer * Math.sin(s)
    x2 = cx + r_outer * Math.cos(e); y2 = cy + r_outer * Math.sin(e)
    x3 = cx + r_inner * Math.cos(e); y3 = cy + r_inner * Math.sin(e)
    x4 = cx + r_inner * Math.cos(s); y4 = cy + r_inner * Math.sin(s)
    "M #{x1.round(2)},#{y1.round(2)} A #{r_outer},#{r_outer} 0 0,1 #{x2.round(2)},#{y2.round(2)} " \
    "L #{x3.round(2)},#{y3.round(2)} A #{r_inner},#{r_inner} 0 0,0 #{x4.round(2)},#{y4.round(2)} Z"
  end

  def label_pos(cx, cy, r, angle_deg)
    rad = (angle_deg - 90) * Math::PI / 180
    [cx + r * Math.cos(rad), cy + r * Math.sin(rad)]
  end
%>

<div class="circle-wrap">
  <svg viewBox="0 0 440 440" xmlns="http://www.w3.org/2000/svg" class="cof-svg" aria-label="Circle of Fifths">
    <!-- outer ring glow -->
    <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= r_outer + 4 %>" fill="none" stroke="#2d2b55" stroke-width="8"/>

    <% fifths.each_with_index do |key, i| %>
      <%
        start_angle = i * deg_per_key - deg_per_key / 2.0
        end_angle   = start_angle + deg_per_key
        mid_angle   = i * deg_per_key
        lx, ly      = label_pos(cx, cy, r_label, mid_angle)
        is_selected = key == selected_key
        seg_fill    = is_selected ? "#7c3aed" : "#1e1b4b"
        seg_stroke  = is_selected ? "#a78bfa" : "#312e81"
        text_fill   = is_selected ? "#ffffff"  : "#a5b4fc"
        font_weight = is_selected ? "bold"     : "normal"
        path_d      = arc_path(cx, cy, r_inner, r_outer, start_angle, end_angle)
      %>
      <a href="<%= key_path(key_name: key) %>" class="cof-segment" data-key="<%= key %>">
        <path d="<%= path_d %>" fill="<%= seg_fill %>" stroke="<%= seg_stroke %>" stroke-width="2"
              class="cof-slice<%= " cof-slice--active" if is_selected %>"/>
        <text x="<%= lx.round(1) %>" y="<%= ly.round(1) %>"
              text-anchor="middle" dominant-baseline="central"
              fill="<%= text_fill %>" font-family="'JetBrains Mono', monospace"
              font-size="<%= is_selected ? 16 : 14 %>" font-weight="<%= font_weight %>"
              class="cof-label">
          <%= key.gsub("#", "♯") %>
        </text>
      </a>
    <% end %>

    <!-- inner hub -->
    <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= r_inner - 4 %>" fill="#0f0e1a"/>
    <text x="<%= cx %>" y="<%= cy - 10 %>" text-anchor="middle" fill="#6366f1"
          font-family="'JetBrains Mono', monospace" font-size="13" font-weight="bold">
      <%= selected_key ? selected_key.gsub("#", "♯") : "?" %>
    </text>
    <text x="<%= cx %>" y="<%= cy + 10 %>" text-anchor="middle" fill="#4338ca"
          font-family="Inter, sans-serif" font-size="10">
      <%= selected_key ? "selected" : "pick a key" %>
    </text>
  </svg>
</div>
